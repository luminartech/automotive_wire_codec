{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        "group:allNonMajor"
    ],
    "rebaseWhen": "never",
    "patch": {
        "enabled": false
    },
    "description": "Schedule on weekdays at night (10 PM - 4 AM) and anytime on weekends",
    "schedule": [
        "* 22-23,0-4 * * *",
        "* * * * 0,6"
    ],
    "stopUpdatingLabel": "Shut Up Renovate",
    "timezone": "EST",
    "assignees": [
        "@luminartech/embedded-build-engineer"
    ],
    "assigneesFromCodeOwners": true,
    "branchPrefix": "chore/",
    "labels": [
        "chore",
        "renovate"
    ],
    "cargo": {
        "fileMatch": ["(^|/)Cargo\\.toml$"]
    }
}
